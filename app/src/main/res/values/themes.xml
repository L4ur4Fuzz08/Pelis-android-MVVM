<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PelisProApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Color Primario (Botones principales, barras) -->
        <item name="colorPrimary">@color/primary_main</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Color Secundario (Chips, elementos menos importantes) -->
        <item name="colorSecondary">@color/secondary_main</item>
        <item name="colorOnSecondary">@color/text_main</item>
        <!-- Color Accent / Terciario (Detalles, acentos visuales) -->
        <item name="colorTertiary">@color/accent_main</item>
        <item name="colorOnTertiary">@color/text_main</item>

        <!-- Fondo y Superficies -->
        <item name="android:windowBackground">@color/background_main</item>
        <item name="colorSurface">@color/background_main</item>
        <item name="colorOnSurface">@color/text_main</item>

        <!-- 2. EL COLOR CLAVE PARA FAB Y BOTTOM NAV (Contenedores) -->
        <!-- En Material 3, el FAB y la "píldora" de selección del menú usan estos: -->
        <item name="colorSecondaryContainer">@color/secondary_main</item>
        <item name="colorOnSecondaryContainer">@color/text_main</item>
    </style>

    <style name="Theme.PelisProApp" parent="Base.Theme.PelisProApp" />
</resources>